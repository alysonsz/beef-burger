@page "/"

<PageTitle>Beef Burger</PageTitle>

<div class="text-center" style="padding: 4rem 0;">
    <h1 style="font-size: 3.5rem; margin-bottom: 1rem;">
        Welcome to <span class="text-primary">Beef Burger</span>
    </h1>
    <p style="font-size: 1.25rem; max-width: 600px; margin: 0 auto 2rem auto;">
        Experience the best burgers in town. Premium ingredients, amazing discounts, and fast delivery.
    </p>
    
    <div style="display: flex; gap: 1rem; justify-content: center;">
        <a href="menu" class="btn btn-primary" style="padding: 1rem 2rem; font-size: 1.125rem;">
            <span class="material-symbols-outlined">restaurant_menu</span> View Menu
        </a>
        <a href="checkout" class="btn btn-outline" style="padding: 1rem 2rem; font-size: 1.125rem;">
            <span class="material-symbols-outlined">shopping_cart</span> Order Now
        </a>
    </div>
</div>

<div class="grid grid-cols-3" style="margin-top: 4rem;">
    <div class="menu-card" style="padding: 2rem; text-align: center;">
        <span class="material-symbols-outlined text-primary" style="font-size: 3rem; margin-bottom: 1rem;">local_fire_department</span>
        <h3>20% Discount</h3>
        <p>Get a full combo (Burger + Fries + Drink) and receive a 20% discount on your order.</p>
    </div>
    <div class="menu-card" style="padding: 2rem; text-align: center;">
        <span class="material-symbols-outlined text-primary" style="font-size: 3rem; margin-bottom: 1rem;">fastfood</span>
        <h3>15% Discount</h3>
        <p>Grab a Burger and a Drink and get 15% off your meal.</p>
    </div>
    <div class="menu-card" style="padding: 2rem; text-align: center;">
        <span class="material-symbols-outlined text-primary" style="font-size: 3rem; margin-bottom: 1rem;">lunch_dining</span>
        <h3>10% Discount</h3>
        <p>Pair your Burger with our crispy Fries to save 10%.</p>
    </div>
</div>
